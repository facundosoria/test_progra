# ─────────────────────────────────────────────────────────────
# Codemon TCG — Variables de entorno
# Copiar como .env y completar los valores marcados con TODO
# NUNCA commitear el archivo .env real
# ─────────────────────────────────────────────────────────────

# ── Base de datos ─────────────────────────────────────────────
DB_NAME=codemon_db
DB_USER=codemon_user
DB_PASSWORD=codemon_pass

# ── MinIO (almacenamiento de imágenes) ────────────────────────
MINIO_USER=codemon
MINIO_PASSWORD=codemon123
MINIO_BUCKET=codemon-cards
# URL que la API guarda en PostgreSQL — siempre vía Nginx, nunca localhost:9000
MINIO_PUBLIC_URL=http://localhost:8088/minio

# ── JWT ───────────────────────────────────────────────────────
# Mínimo 32 caracteres, aleatorio, secreto
JWT_SECRET=TODO_cambiar_por_secreto_aleatorio_min32chars
JWT_EXPIRY_MS=900000
REFRESH_TOKEN_EXPIRY_MS=604800000

# ── Email SMTP (verificación 2FA) ─────────────────────────────
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
# TODO: cuenta Gmail del proyecto (usar App Password, no la contraseña normal)
EMAIL_USERNAME=
EMAIL_PASSWORD=
# Alternativa para desarrollo local: MailHog en localhost:1025

# ── Mercado Pago ──────────────────────────────────────────────
# TODO: obtener de developers.mercadopago.com (credenciales TEST-)
MP_ACCESS_TOKEN=
MP_SANDBOX=true

# ── CORS ──────────────────────────────────────────────────────
# Agregar http://localhost:4200 si el frontend corre fuera de Docker en dev
CORS_ALLOWED_ORIGINS=http://localhost:8088

# ── Grafana ───────────────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=codemon123

# ─────────────────────────────────────────────────────────────
# Codemon TCG — Production environment template
# Copy as .env.production and replace every placeholder before deploy.
# Do not commit .env.production or real secrets.
# ─────────────────────────────────────────────────────────────

# Public HTTPS domain
PUBLIC_BASE_URL=https://<dominio>
MINIO_PUBLIC_URL=https://<dominio>/minio
CORS_ALLOWED_ORIGINS=https://<dominio>
TLS_CERTS_DIR=./infra/certs

# Database
DB_NAME=codemon_db
DB_USER=codemon_user
DB_PASSWORD=CHANGE_ME_PRODUCTION_DB_PASSWORD

# MinIO
MINIO_USER=codemon
MINIO_PASSWORD=CHANGE_ME_PRODUCTION_MINIO_PASSWORD
MINIO_BUCKET=codemon-cards

# JWT
JWT_SECRET=CHANGE_ME_RANDOM_SECRET_MIN_32_CHARS
JWT_EXPIRY_MS=900000
REFRESH_TOKEN_EXPIRY_MS=604800000

# Email SMTP
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_USERNAME=CHANGE_ME_SMTP_USERNAME
EMAIL_PASSWORD=CHANGE_ME_SMTP_APP_PASSWORD

# Mercado Pago
MP_ACCESS_TOKEN=CHANGE_ME_PRODUCTION_MP_ACCESS_TOKEN
MP_SANDBOX=false

# Grafana internal admin. The production compose overlay does not expose Grafana publicly.
GRAFANA_USER=admin
GRAFANA_PASSWORD=CHANGE_ME_PRODUCTION_GRAFANA_PASSWORD
